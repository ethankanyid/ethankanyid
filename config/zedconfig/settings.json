// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "chat_panel": {
    "dock": "left"
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },

  "terminal": {
    "dock": "bottom",
    "button": true
  },

  "notification_panel": {
    "dock": "left",
    "button": false
  },

  "project_panel": {
    "dock": "right",
    "button": true
  },

  "outline_panel": {
    "dock": "right"
  },

  "collaboration_panel": {
    "dock": "left",
    "button": true
  },

  "assistant": {
    "enabled": false,
    "dock": "left",
    "button": false
  },

  "features": {
    "inline_completion_provider": "none", //zed, supermaven, or copilot
    "chat_panel": false
  },

  "ui_font_size": 16,
  "buffer_font_size": 16,

  "theme": {
    "mode": "light",
    "light": "XY-Zed",
    "dark": "VSCode Dark High Contrast"
  }
}
